# Copy this file to `.env` and fill in values from your Supabase project
# (Project Settings → API). The real `.env` is gitignored — never commit keys.

# --- Used by the web app (browser-safe, exposed in the bundle) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Used ONLY by scripts/upsert-links.mjs (server-side, keep secret) ---
# The service_role key bypasses Row Level Security so the batch routine can
# insert/update links. Never expose it in the browser or commit it.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
